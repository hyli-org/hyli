ARG DEP_IMAGE=rust:bookworm

FROM ${DEP_IMAGE} AS builder

WORKDIR /usr/src/hyli

COPY Cargo.toml Cargo.lock ./
COPY .cargo/config.toml .cargo/config.toml
COPY src ./src
COPY crates ./crates
RUN cargo build --release -p hyli-sp1-verifier-worker

FROM scratch
COPY --from=builder /usr/src/hyli/target/release/hyli-sp1-verifier /hyli-sp1-verifier
